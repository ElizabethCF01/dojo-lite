# Base URL of the dojolite-api backend.
# iOS simulator: localhost works. Android emulator: use http://10.0.2.2:3333
# Physical device (Expo Go): use your machine's LAN IP, e.g. http://192.168.x.x:3333
# Non-secret (it gets inlined into the client bundle), so it's committed for a
# working out-of-the-box default.
EXPO_PUBLIC_API_URL=http://localhost:3333
